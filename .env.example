# ─────────────────────────────────────────────────────
# AbsoluteLabs AI Delivery Copilot — Environment Variables
# Copy this file to .env and fill in your keys
# Add these same keys to Vercel → Project Settings → Environment Variables
# ─────────────────────────────────────────────────────

# ── Backend server URL ──────────────────────────────────────────────────────────
# LOCAL DEV: Leave blank — app auto-falls back to http://localhost:3001
# VERCEL / PRODUCTION: Set to your deployed Express server URL
#   e.g. VITE_BACKEND_URL=https://your-api.railway.app
# IMPORTANT: Must start with VITE_ so Vite exposes it to the browser build
VITE_BACKEND_URL=

# ── OPTION 1: Google Gemini (RECOMMENDED — 100% FREE) ──
# Get key: https://aistudio.google.com/app/apikey
# Just sign in with your Google account → Create API Key → Done
# Free tier: 15 requests/min, 1 million tokens/day — more than enough
GEMINI_API_KEY=AIzaSyxxxxxxxxxxxxxxxxxxxxxxxx

# ── OPTION 2: Anthropic Claude (optional fallback) ──
# Get key: https://console.anthropic.com → API Keys → Create Key
# $5 free credit on new accounts
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx

# ZOHO DESK (optional — mock data used if not set)
# Get key: Zoho Desk → Setup → Developer Space → API → Self Client
# Or ask your org admin for the credentials
ZOHO_ORG_ID=
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REFRESH_TOKEN=

# ZOHO DESK — Per-project Department IDs (for project-wise ticket filtering)
# Get from: Zoho Desk → Setup → Departments → click a dept → copy the ID from the URL
ZOHO_DEPT_MULBERRY=
ZOHO_DEPT_WOLVERINE=
ZOHO_DEPT_CLARKS=
ZOHO_DEPT_HARVEY=
ZOHO_DEPT_WREN=
ZOHO_DEPT_BARBOUR=
ZOHO_DEPT_FOOTASYLUM=

# JIRA (optional — mock data used if not set)
# Get token: https://id.atlassian.com → Security → API Tokens
# JIRA_HOST = your-org.atlassian.net (no https://)
JIRA_HOST=
JIRA_EMAIL=
JIRA_API_TOKEN=
JIRA_PROJECT_KEY=

# DATADOG (optional — mock data used if not set)
# Get keys: Datadog → Organisation Settings → API Keys / Application Keys
DATADOG_API_KEY=
DATADOG_APP_KEY=
